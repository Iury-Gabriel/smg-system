PORT=3344
NODE_ENV=development

# Workflow database URL (PostgreSQL)
# Em docker compose deste projeto:
# postgresql://smg:smg123@postgres:5432/smg?schema=public
DATABASE_URL=postgresql://smg:smg123@localhost:5432/smg?schema=public
DEFAULT_WORKFLOW=smg

# Queue / Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=smg
BULLMQ_QUEUE_NAME=smg-scrap-queue
WORKER_CONCURRENCY=10
WORKER_VERBOSE_LOGS=true
WORKER_LEAD_LOG_LIMIT=0

# SerpAPI
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
SERPAPI_TIMEOUT_MS=30000
SERPAPI_MAX_START=200

# Schedule
SCRAPER_CRON_SMG=0 9 * * *
SCRAPER_CRON_BSB=0 10 * * *
WORKFLOW_DEFAULT_AGENT_SMG=default-sdr
WORKFLOW_DEFAULT_AGENT_BSB=default-sdr
SCRAPER_TIMEZONE=America/Sao_Paulo

# Enrichment
ENABLE_WEBSITE_ENRICHMENT=true

# Public webhook base URL (optional but recommended behind proxy)
PUBLIC_WEBHOOK_BASE_URL=

# Providers (global defaults)
META_GRAPH_BASE_URL=https://graph.facebook.com/v23.0
META_WEBHOOK_VERIFY_TOKEN=
UAZAPI_BASE_URL=
UAZAPI_SEND_MESSAGE_PATH=/send/text
UAZAPI_SEND_MEDIA_PATH=/send/media

# OpenAI / AI orchestration (global defaults)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_DEFAULT_BUFFER_SECONDS=15
AGENT_CONVERSATION_HISTORY_LIMIT=20
AGENT_REPLY_CHUNK_MAX_LENGTH=420
WF2_POLL_INTERVAL_SECONDS=30
WF2_ENABLE_OUTBOUND_START=false
ALLOW_OUTBOUND_MESSAGES=false

# Agent registry behavior
AGENT_REGISTRY_HOT_RELOAD=false

# Supabase Edge Function proxy (used by /api/integrations/supabase/create-ldr-lead)
SUPABASE_CREATE_LDR_LEAD_URL=https://qqslhlkdjiukvjxodzpv.supabase.co/functions/v1/create-ldr-lead
SUPABASE_ANON_KEY=

# Agent: default-sdr (Meta Official)
AGENT_DEFAULT_SDR_META_VERIFY_TOKEN=
AGENT_DEFAULT_SDR_META_ACCESS_TOKEN=
AGENT_DEFAULT_SDR_META_PHONE_NUMBER_ID=
AGENT_DEFAULT_SDR_META_WABA_ID=
AGENT_DEFAULT_SDR_META_GRAPH_BASE_URL=

# Agent: default-sdr (Uazapi)
AGENT_DEFAULT_SDR_UAZAPI_BASE_URL=
AGENT_DEFAULT_SDR_UAZAPI_INSTANCE_TOKEN=
AGENT_DEFAULT_SDR_UAZAPI_WEBHOOK_SECRET=
AGENT_DEFAULT_SDR_UAZAPI_SEND_PATH=/send/text

# Agent: default-sdr (AI orchestration)
AGENT_DEFAULT_SDR_WORKFLOW=smg
AGENT_DEFAULT_SDR_AI_ENABLED=true
AGENT_DEFAULT_SDR_OPENAI_API_KEY=
AGENT_DEFAULT_SDR_OPENAI_MODEL=gpt-4o-mini
AGENT_DEFAULT_SDR_BUFFER_SECONDS=15
AGENT_DEFAULT_SDR_HISTORY_LIMIT=20
AGENT_DEFAULT_SDR_HUMAN_HANDOFF=true
AGENT_DEFAULT_SDR_CLEAR_MEMORY_COMMAND=true
AGENT_DEFAULT_SDR_FORM_LINK=https://sistema.smgcompany.com.br/diagnostico
AGENT_DEFAULT_SDR_PIPELINE_ORIGIN=automacao
AGENT_DEFAULT_SDR_CHANNEL=scrap_smg
AGENT_DEFAULT_SDR_META_TEMPLATE_INITIAL_OUTBOUND=
AGENT_DEFAULT_SDR_META_TEMPLATE_FUP1=
AGENT_DEFAULT_SDR_META_TEMPLATE_FUP2=
AGENT_DEFAULT_SDR_META_TEMPLATE_FUP3=
AGENT_DEFAULT_SDR_META_TEMPLATE_FUP_RECORRENTE=
AGENT_DEFAULT_SDR_META_TEMPLATE_ANALISE=

{
  "name": "backend-smg-system",
  "version": "1.0.0",
  "private": true,
  "description": "SMG Scrap backend with BullMQ + Prisma + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/start-all.js",
    "start:server": "node src/server.js",
    "worker": "node src/queue/worker.js",
    "enqueue": "node src/queue/enqueue-manual.js",
    "scheduler": "node src/queue/scheduler.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "seed": "node prisma/seed.js",
    "seed:smg": "node prisma/seed.js --workflow=smg",
    "seed:bsb": "node prisma/seed.js --workflow=bsb",
    "test:e2e:wf2-inbound": "node scripts/test-wf2-inbound-e2e.js"
  },
  "dependencies": {
    "@langchain/core": "^0.3.68",
    "@langchain/openai": "^0.6.16",
    "@prisma/client": "^6.19.0",
    "axios": "^1.9.0",
    "bullmq": "^5.56.0",
    "cheerio": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "morgan": "^1.10.0",
    "pdfkit": "^0.17.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.19.0"
  }
}
